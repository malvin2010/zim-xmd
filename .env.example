# ZIM XMD ULTIMATE — Environment Variables
# Copy this file to .env and fill in your values

# Your WhatsApp number with country code (no + or spaces)
OWNER_NUMBER=263XXXXXXXXX

# Session ID from pairing (auto-generated after pairing)
SESSION_ID=

# Optional API keys for extended features
OMDB_KEY=        # https://www.omdbapi.com/apikey.aspx
GNEWS_KEY=       # https://gnews.io
PINTEREST_KEY=   # https://developers.pinterest.com
GEMINI_KEY=      # https://ai.google.dev

# Server port (Render sets this automatically)
PORT=3000
